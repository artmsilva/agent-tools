{
  "name": "pi-working-message",
  "version": "0.1.0",
  "description": "Replaces pi's opaque 'Working...' line with a live, phase-aware status: waiting for the model, streaming tokens, or running a specific tool, each with elapsed time and a stall warning past ~15s idle.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "status",
    "observability"
  ],
  "author": "Arturo Silva",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artmsilva/agent-tools.git",
    "directory": "packages/pi-working-message"
  },
  "bugs": {
    "url": "https://github.com/artmsilva/agent-tools/issues"
  },
  "homepage": "https://github.com/artmsilva/agent-tools/tree/main/packages/pi-working-message#readme",
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "status.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit && bun test",
    "test": "bun test"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.0",
    "@types/node": "^22.20.1",
    "bun-types": "^1.3.8",
    "typescript": "^5.6.0"
  }
}
